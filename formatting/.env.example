# Azure OpenAI (use these for Azure)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Or standard OpenAI (if not using Azure)
# OPENAI_API_KEY=sk-...

# Or Google Gemini (set GEMINI_API_KEY or GOOGLE_API_KEY; optional FORMATTER_LLM_PROVIDER=gemini)
# GEMINI_API_KEY=your-google-ai-studio-key
# GEMINI_MODEL=gemini-1.5-pro
# GOOGLE_API_KEY=...  # alternative to GEMINI_API_KEY
# FORMATTER_LLM_PROVIDER=gemini

# Optional: model name (OpenAI/Azure: gpt-4o-mini; Gemini: GEMINI_MODEL or FORMATTER_LLM_MODEL)
# FORMATTER_LLM_MODEL=gpt-4o-mini
# FORMATTER_LLM_MODEL=gemini-1.5-pro
