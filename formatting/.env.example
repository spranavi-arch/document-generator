# Google Gemini (required for LLM formatting)
GEMINI_API_KEY=your-google-ai-studio-key
# GEMINI_MODEL=gemini-1.5-pro
# GOOGLE_API_KEY=...  # alternative to GEMINI_API_KEY

# Optional: model name
# FORMATTER_LLM_MODEL=gemini-1.5-pro
# FORMATTER_LLM_MAX_TOKENS=16384

# Optional: multi-agent slot-fill (one call per section)
# FORMATTER_MULTI_AGENT=1
# FORMATTER_MULTI_AGENT_MAX_WORKERS=5

# Optional: one template page per minute (rate limiting)
# FORMATTER_ONE_IMAGE_PER_MINUTE=1
# FORMATTER_ONE_IMAGE_PER_MINUTE_DELAY_SECONDS=60
